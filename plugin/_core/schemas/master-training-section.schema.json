{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/david-deji/comp-comms-builder/master-schema/master-training-section.schema.json",
  "title": "Master Training Section",
  "description": "Validates master.training.* per spec § 5.3. Owned exclusively by comp-training-designer. Other skills MUST NOT write to this section.",
  "type": "object",
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
      "description": "Per-section semver per § 12.4. Independent of other sections."
    },
    "audience_archetypes": {
      "type": "array",
      "description": "Long-lived org-level audience learning archetypes. Carry across cycles.",
      "items": {
        "type": "object",
        "properties": {
          "audience": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$",
            "description": "Audience identifier (e.g., 'hourly_union', 'people_managers', 'salaried_corporate')."
          },
          "depth_tier": {
            "type": "string",
            "enum": ["foundational", "intermediate", "advanced"],
            "description": "Learning depth appropriate for this audience."
          },
          "preferred_blocks": {
            "type": "array",
            "items": {"type": "string"},
            "description": "Training block types that work well for this audience (e.g., 'poll', 'scenario', 'quiz', 'retrieval')."
          },
          "avoid_blocks": {
            "type": "array",
            "items": {"type": "string"},
            "description": "Block types that do not suit this audience."
          },
          "last_updated": {
            "type": "string",
            "format": "date",
            "description": "Used for tree-view freshness signals per § 7.3."
          }
        },
        "required": ["audience", "depth_tier", "preferred_blocks", "avoid_blocks", "last_updated"],
        "additionalProperties": false
      }
    },
    "shipped_modules": {
      "type": "array",
      "description": "Registry of final training modules delivered per cycle.",
      "items": {
        "type": "object",
        "properties": {
          "cycle_slug": {
            "type": "string",
            "description": "Cycle in which this module was produced."
          },
          "module": {
            "type": "string",
            "description": "Module identifier or title (e.g., 'annual-review-conversations')."
          },
          "audience": {
            "type": "string",
            "description": "Target audience identifier for this module."
          },
          "shipped_date": {
            "type": "string",
            "format": "date",
            "description": "Date the module was delivered."
          },
          "file": {
            "type": "string",
            "description": "Relative path to the shipped module file."
          }
        },
        "required": ["cycle_slug", "module", "audience", "shipped_date", "file"],
        "additionalProperties": false
      }
    },
    "cycle_state_pointers": {
      "type": "array",
      "description": "Per-cycle state file pointers. Actual cycle data lives in cycle_dir/training/.",
      "items": {
        "type": "object",
        "properties": {
          "cycle_slug": {
            "type": "string",
            "description": "References a cycle_slug in master.cycles[]."
          },
          "state_file": {
            "type": "string",
            "description": "Relative path to the per-cycle training config file."
          }
        },
        "required": ["cycle_slug", "state_file"],
        "additionalProperties": false
      }
    },
    "pre_engagement_artifacts": {
      "type": "array",
      "description": "Pre-engagement artifacts produced before or outside the canonical engagement spine. NOT included in closed-engagement drift queries.",
      "items": {
        "type": "object",
        "required": ["artifact_slug", "engagement_mode", "created_date", "intended_drive_path"],
        "properties": {
          "artifact_slug": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]*$",
            "description": "Stable identifier for this pre-engagement artifact."
          },
          "engagement_mode": {
            "type": "string",
            "enum": ["audience-design-only", "ingest-only"],
            "description": "The partial-flow mode used to produce this artifact. council-deliberation is standalone (not pre-engagement); cascade-only and single-audience require a prior deck."
          },
          "created_date": {
            "type": "string",
            "format": "date",
            "description": "ISO date when the artifact was created."
          },
          "intended_drive_path": {
            "type": "string",
            "description": "Intended Drive path for the artifact file."
          },
          "decision_log_ref": {
            "type": "string",
            "description": "Pointer to the decision_log entry (dl-NNN) that captures the pre-engagement mode rationale."
          }
        },
        "additionalProperties": false
      }
    }
  },
  "required": ["schema_version"],
  "additionalProperties": false,
  "examples": [
    {
      "schema_version": "1.0.0",
      "audience_archetypes": [
        {
          "audience": "hourly_union",
          "depth_tier": "foundational",
          "preferred_blocks": ["poll", "scenario"],
          "avoid_blocks": ["retrieval"],
          "last_updated": "2026-03-12"
        },
        {
          "audience": "people_managers",
          "depth_tier": "intermediate",
          "preferred_blocks": ["quiz", "scenario", "retrieval"],
          "avoid_blocks": [],
          "last_updated": "2026-03-12"
        }
      ],
      "shipped_modules": [
        {
          "cycle_slug": "pharmacy-qc-fy26",
          "module": "annual-review-conversations",
          "audience": "people_managers",
          "shipped_date": "2026-03-20",
          "file": "_orgs/acme/cycles/pharmacy-qc-fy26/training/modules/annual-review-conversations.md"
        }
      ],
      "cycle_state_pointers": [
        {
          "cycle_slug": "pharmacy-qc-fy26",
          "state_file": "_orgs/acme/cycles/pharmacy-qc-fy26/training/engagement-training-config.yaml"
        }
      ]
    }
  ]
}
